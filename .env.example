# ── Application ──────────────────────────────────────────────────
APP_PORT=3000

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_EXPIRATION=1d

# ── Security ─────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=10

# ── Seed ─────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe@2026!

# ── SQL Server ───────────────────────────────────────────────────
MSSQL_HOST=aivacol_sqlserver
MSSQL_USER=sa
MSSQL_SA_PASSWORD=YourStrong@Password!
MSSQL_PORT=1433
MSSQL_DB=aivacol_db
ACCEPT_EULA=Y
TYPEORM_SYNCHRONIZE=false
TYPEORM_LOGGING=false
TYPEORM_RUN_MIGRATIONS=true

# ── Redis ────────────────────────────────────────────────────────
REDIS_HOST=aivacol_redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme
CACHE_TTL_SECONDS=60

# ── RabbitMQ ─────────────────────────────────────────────────────
RABBITMQ_HOST=aivacol_rabbitmq
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=changeme
RABBITMQ_VHOST=aivacol_vhost
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ── MongoDB ──────────────────────────────────────────────────────
MONGO_HOST=aivacol_mongodb
MONGO_USER=admin
MONGO_PASSWORD=changeme
MONGO_DB=aivacol_audit
MONGO_PORT=27017
